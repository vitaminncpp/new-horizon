generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum course_level {
  beginner
  intermediate
  advanced
}

enum course_status {
  draft
  published
  archived
}

enum enrollment_status {
  active
  completed
  paused
  dropped
}

enum lesson_type {
  video
  article
  live_session
  quiz
  coding_lab
}

enum content_block_type {
  markdown
  code
  embed
  resource
}

enum lesson_progress_status {
  not_started
  in_progress
  completed
}

enum assessment_type {
  practice
  graded
  final_exam
}

enum question_type {
  single_choice
  multiple_choice
  short_text
  code
}

enum attempt_status {
  in_progress
  submitted
  graded
}

enum submission_status {
  draft
  submitted
  passed
  failed
}

enum user_role {
  learner
  instructor
  admin
}

model user {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String @db.VarChar(255)
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  role     user_role @default(learner)
  session_version Int @default(1)

  created_courses      course[]              @relation("course_creator")
  enrollments          course_enrollment[]
  lesson_progresses    lesson_progress[]
  assessment_attempts  assessment_attempt[]
  exercise_submissions exercise_submission[]

  created_at DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at DateTime? @db.Timestamptz(6)
  is_deleted Boolean   @default(false) @db.Boolean

  @@map("users")
  @@index([role])
}

model course {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creator_id        String        @db.Uuid
  title             String        @db.VarChar(255)
  slug              String        @unique @db.VarChar(255)
  summary           String?       @db.VarChar(500)
  description       String?
  thumbnail_url     String?       @db.VarChar(2048)
  estimated_minutes Int?
  level             course_level  @default(beginner)
  status            course_status @default(draft)
  published_at      DateTime?     @db.Timestamptz(6)

  creator     user                @relation("course_creator", fields: [creator_id], references: [id])
  sections    course_section[]
  enrollments course_enrollment[]
  assessments assessment[]

  is_deleted Boolean   @default(false) @db.Boolean
  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@index([creator_id])
  @@index([status])
  @@map("courses")
}

model course_section {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_id   String  @db.Uuid
  title       String  @db.VarChar(255)
  description String?
  position    Int

  course  course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons lesson[]

  is_deleted Boolean   @default(false) @db.Boolean
  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([course_id, position])
  @@index([course_id])
  @@map("course_sections")
}

model lesson {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  section_id        String      @db.Uuid
  title             String      @db.VarChar(255)
  slug              String      @db.VarChar(255)
  description       String?
  type              lesson_type @default(article)
  position          Int
  estimated_minutes Int?
  is_preview        Boolean     @default(false) @db.Boolean

  section          course_section        @relation(fields: [section_id], references: [id], onDelete: Cascade)
  content_blocks   lesson_content_block[]
  progresses       lesson_progress[]
  assessments      assessment[]
  coding_exercises coding_exercise[]

  is_deleted Boolean   @default(false) @db.Boolean
  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([section_id, position])
  @@unique([section_id, slug])
  @@index([section_id])
  @@map("lessons")
}

model lesson_content_block {
  id         String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lesson_id  String             @db.Uuid
  type       content_block_type
  title      String?            @db.VarChar(255)
  content    Json
  position   Int

  lesson lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([lesson_id, position])
  @@index([lesson_id])
  @@map("lesson_content_blocks")
}

model course_enrollment {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_id        String            @db.Uuid
  user_id          String            @db.Uuid
  status           enrollment_status @default(active)
  progress_percent Decimal           @default(0) @db.Decimal(5, 2)
  enrolled_at      DateTime          @default(now()) @db.Timestamptz(6)
  completed_at     DateTime?         @db.Timestamptz(6)
  last_accessed_at DateTime?         @db.Timestamptz(6)

  course course @relation(fields: [course_id], references: [id], onDelete: Cascade)
  user   user   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([course_id, user_id])
  @@index([user_id, status])
  @@index([course_id, status])
  @@map("course_enrollments")
}

model lesson_progress {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lesson_id          String                 @db.Uuid
  user_id            String                 @db.Uuid
  status             lesson_progress_status @default(not_started)
  progress_percent   Decimal                @default(0) @db.Decimal(5, 2)
  started_at         DateTime?              @db.Timestamptz(6)
  completed_at       DateTime?              @db.Timestamptz(6)
  last_interacted_at DateTime?              @db.Timestamptz(6)

  lesson lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  user   user   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([lesson_id, user_id])
  @@index([user_id, status])
  @@index([lesson_id, status])
  @@map("lesson_progresses")
}

model assessment {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_id       String          @db.Uuid
  lesson_id       String?         @db.Uuid
  title           String          @db.VarChar(255)
  description     String?
  type            assessment_type @default(practice)
  passing_score   Int?
  max_attempts    Int?
  time_limit_mins Int?
  is_published    Boolean         @default(false) @db.Boolean

  course   course               @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lesson   lesson?              @relation(fields: [lesson_id], references: [id], onDelete: SetNull)
  questions assessment_question[]
  attempts  assessment_attempt[]

  is_deleted Boolean   @default(false) @db.Boolean
  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@index([course_id])
  @@index([lesson_id])
  @@map("assessments")
}

model assessment_question {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id       String        @db.Uuid
  prompt              String
  type                question_type
  position            Int
  points              Int           @default(1)
  explanation         String?
  correct_text_answer String?
  code_template      String?
  code_language      String?       @db.VarChar(50)
  metadata           Json?

  assessment assessment      @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  options    question_option[]
  answers    attempt_answer[]

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([assessment_id, position])
  @@index([assessment_id])
  @@map("assessment_questions")
}

model question_option {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question_id String  @db.Uuid
  label       String? @db.VarChar(50)
  content     String
  position    Int
  is_correct  Boolean @default(false) @db.Boolean

  question assessment_question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([question_id, position])
  @@index([question_id])
  @@map("question_options")
}

model assessment_attempt {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id  String         @db.Uuid
  user_id        String         @db.Uuid
  attempt_number Int
  status         attempt_status @default(in_progress)
  score          Decimal?       @db.Decimal(6, 2)
  started_at     DateTime       @default(now()) @db.Timestamptz(6)
  submitted_at   DateTime?      @db.Timestamptz(6)
  graded_at      DateTime?      @db.Timestamptz(6)

  assessment assessment    @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  user       user          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  answers    attempt_answer[]

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([assessment_id, user_id, attempt_number])
  @@index([user_id, status])
  @@index([assessment_id, status])
  @@map("assessment_attempts")
}

model attempt_answer {
  id                    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_attempt_id String  @db.Uuid
  question_id          String  @db.Uuid
  selected_option_ids  Json?
  text_answer          String?
  code_answer          String?
  is_correct           Boolean?
  score_awarded        Decimal? @db.Decimal(6, 2)
  feedback             String?

  assessment_attempt assessment_attempt @relation(fields: [assessment_attempt_id], references: [id], onDelete: Cascade)
  question           assessment_question @relation(fields: [question_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([assessment_attempt_id, question_id])
  @@index([question_id])
  @@map("attempt_answers")
}

model coding_exercise {
  id                  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lesson_id           String  @db.Uuid
  title               String  @db.VarChar(255)
  prompt              String
  starter_code        String?
  solution_code       String?
  language            String  @db.VarChar(50)
  test_cases          Json?
  max_score           Int     @default(100)

  lesson      lesson                 @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  submissions exercise_submission[]

  is_deleted Boolean   @default(false) @db.Boolean
  deleted_at DateTime? @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@index([lesson_id])
  @@map("coding_exercises")
}

model exercise_submission {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coding_exercise_id String            @db.Uuid
  user_id            String            @db.Uuid
  submission_number  Int
  code               String
  language           String            @db.VarChar(50)
  status             submission_status @default(draft)
  score              Decimal?          @db.Decimal(6, 2)
  test_results       Json?
  submitted_at       DateTime?         @db.Timestamptz(6)

  coding_exercise coding_exercise @relation(fields: [coding_exercise_id], references: [id], onDelete: Cascade)
  user            user            @relation(fields: [user_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@unique([coding_exercise_id, user_id, submission_number])
  @@index([user_id, status])
  @@index([coding_exercise_id, status])
  @@map("exercise_submissions")
}
